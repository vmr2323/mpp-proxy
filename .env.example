# Required: Tempo wallet address that receives payments (42 chars, 0x-prefixed)
MPP_RECIPIENT=0xYourWalletAddressHere

# Required: 64-char hex secret for MPP payment verification
MPP_SECRET_KEY=

# Optional: price per request in USDC.e decimal string (default: 0.01 = one cent)
PRICE=0.01

# Optional: comma-separated allowed proxy domains
# ALLOWED_DOMAINS=api.coingecko.com,api.binance.com,api.kraken.com
